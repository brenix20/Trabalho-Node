<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestor — IPCAVNF</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main-container">
  <% function estadoBadgeClass(estado) {
      if (estado === 'Aprovada') return 'badge-estado badge-estado-aprovada';
      if (estado === 'Rejeitada') return 'badge-estado badge-estado-rejeitada';
      return 'badge-estado badge-estado-pendente';
    } %>

  <% if (mensagem) { %>
    <div class="message <%= tipo %>"><%= mensagem %></div>
  <% } %>

  <!-- ═══ DISCIPLINAS ═══════════════════════════════════════════ -->
  <% if (table === 'disciplina') { %>
    <h2>Disciplinas</h2>
    <div class="table-scroll">
      <table>
        <tr><th>ID</th><th>Disciplina</th><th>Sigla</th><th>Ações</th></tr>
        <% disciplinas.forEach(d => { %>
          <tr>
            <td><%= d.IdDisciplina %></td>
            <td><%= d.Disciplina %></td>
            <td><%= d.Sigla %></td>
            <td class="actions">
              <a class="table-action-btn" href="/gestor?table=disciplina&action=edit&id=<%= d.IdDisciplina %>">Editar</a>
              <form class="inline" method="post" action="/gestor"
                    onsubmit="return confirm('Remover disciplina?')">
                <input type="hidden" name="table"         value="disciplina">
                <input type="hidden" name="action"        value="delete">
                <input type="hidden" name="IdDisciplina"  value="<%= d.IdDisciplina %>">
                <button class="table-action-btn danger-button" type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (!disciplinas.length) { %>
          <tr><td colspan="4">Nenhuma disciplina encontrada.</td></tr>
        <% } %>
      </table>
    </div>

    <div class="form-box">
      <h3><%= editData ? 'Editar Disciplina' : 'Nova Disciplina' %></h3>
      <form method="post" action="/gestor">
        <input type="hidden" name="table"  value="disciplina">
        <input type="hidden" name="action" value="<%= editData ? 'update' : 'create' %>">
        <% if (editData) { %>
          <input type="hidden" name="IdDisciplina" value="<%= editData.IdDisciplina %>">
        <% } %>
        <label>Disciplina</label><br>
        <input type="text" name="Disciplina" maxlength="30" required
               value="<%= editData ? editData.Disciplina : '' %>"><br>
        <label>Sigla</label><br>
        <input type="text" name="Sigla" maxlength="10" required
               value="<%= editData ? editData.Sigla : '' %>"><br>
        <button type="submit"><%= editData ? 'Atualizar' : 'Criar' %></button>
        <% if (editData) { %><a class="cancel-link" href="/gestor?table=disciplina">Cancelar</a><% } %>
      </form>
    </div>
  <% } %>

  <!-- ═══ CURSOS ════════════════════════════════════════════════ -->
  <% if (table === 'cursos') { %>
    <h2>Cursos</h2>
    <div class="table-scroll">
      <table>
        <tr><th>ID</th><th>Curso</th><th>Sigla</th><th>Ações</th></tr>
        <% cursos.forEach(c => { %>
          <tr>
            <td><%= c.IdCurso %></td>
            <td><%= c.Curso %></td>
            <td><%= c.Sigla %></td>
            <td class="actions">
              <a class="table-action-btn" href="/gestor?table=cursos&action=edit&id=<%= c.IdCurso %>">Editar</a>
              <form class="inline" method="post" action="/gestor"
                    onsubmit="return confirm('Remover curso?')">
                <input type="hidden" name="table"   value="cursos">
                <input type="hidden" name="action"  value="delete">
                <input type="hidden" name="IdCurso" value="<%= c.IdCurso %>">
                <button class="table-action-btn danger-button" type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (!cursos.length) { %>
          <tr><td colspan="4">Nenhum curso encontrado.</td></tr>
        <% } %>
      </table>
    </div>

    <div class="form-box">
      <h3><%= editData ? 'Editar Curso' : 'Novo Curso' %></h3>
      <form method="post" action="/gestor">
        <input type="hidden" name="table"  value="cursos">
        <input type="hidden" name="action" value="<%= editData ? 'update' : 'create' %>">
        <% if (editData) { %>
          <input type="hidden" name="IdCurso" value="<%= editData.IdCurso %>">
        <% } %>
        <label>Curso</label><br>
        <input type="text" name="Curso" maxlength="150" required
               value="<%= editData ? editData.Curso : '' %>"><br>
        <label>Sigla</label><br>
        <input type="text" name="Sigla" maxlength="10" required
               value="<%= editData ? editData.Sigla : '' %>"><br>
        <button type="submit"><%= editData ? 'Atualizar' : 'Criar' %></button>
        <% if (editData) { %><a class="cancel-link" href="/gestor?table=cursos">Cancelar</a><% } %>
      </form>
    </div>
  <% } %>

  <!-- ═══ MATRÍCULAS ═══════════════════════════════════════════ -->
  <% if (table === 'matriculas') { %>
    <% if (action === 'ficha' && fichaDetalhes) { %>
      <h2>Ficha do Aluno</h2>
      <p style="margin-bottom: 1.5rem;"><a class="cancel-link" href="/gestor?table=matriculas">Voltar</a></p>

      <div class="ficha-box">
        <div class="ficha-foto">
          <% if (fichaDetalhes.FotoBase64) { %>
            <img src="<%= fichaDetalhes.FotoBase64 %>" alt="Foto">
          <% } %>
        </div>
        <div class="ficha-dados">
          <p><strong>ID Aluno:</strong> <%= fichaDetalhes.IdAluno %></p>
          <p><strong>Nome:</strong> <%= fichaDetalhes.Nome %></p>
          <p><strong>Curso:</strong> <%= fichaDetalhes.Curso %></p>
          <p><strong>Data de Nascimento:</strong> <%= fichaDetalhes.DataNascimentoFmt %></p>
          <p><strong>Email:</strong> <%= fichaDetalhes.Email || '-' %></p>
          <p><strong>Telefone:</strong> <%= fichaDetalhes.Telefone || '-' %></p>
          <p><strong>Morada:</strong> <%= fichaDetalhes.Morada || '-' %></p>
          <p><strong>Estado da Validação:</strong>
            <span class="<%= estadoBadgeClass(fichaDetalhes.EstadoValidacao) %>"><%= fichaDetalhes.EstadoValidacao || 'Pendente' %></span>
          </p>
          <% if (fichaDetalhes.ValidadoPor) { %>
            <p><strong>Validado Por:</strong> <%= fichaDetalhes.ValidadoPor %></p>
          <% } %>
          <% if (fichaDetalhes.DataValidacao) { %>
            <p><strong>Data de Validação:</strong> <%= formatDatePt(fichaDetalhes.DataValidacao) %></p>
          <% } %>
          <% if (fichaDetalhes.ObservacoesValidacao) { %>
            <p><strong>Observação:</strong> <%= fichaDetalhes.ObservacoesValidacao %></p>
          <% } %>
          <% if (fichaDetalhes.EstadoValidacao === 'Pendente') { %>
            <div style="margin-top: 1rem;">
              <form method="post" action="/gestor" style="display:flex; flex-direction:column; gap:0.5rem;">
                <input type="hidden" name="table" value="matriculas">
                <input type="hidden" name="action" value="set_validation">
                <input type="hidden" name="IdAluno" value="<%= fichaDetalhes.IdAluno %>">
                <label style="font-size:0.95rem; font-weight:600;">Observações (opcional)</label>
                <textarea name="ObservacoesValidacao" rows="3" maxlength="255" placeholder="Observações" style="width:100%;"></textarea>
                <div style="display:flex; gap:0.5rem; margin-top:0.25rem;">
                  <button class="table-action-btn" type="submit" name="EstadoValidacao" value="Aprovada">Aceitar Ficha</button>
                  <button class="table-action-btn danger-button" type="submit" name="EstadoValidacao" value="Rejeitada" onclick="return confirm('Rejeitar esta ficha?')">Rejeitar Ficha</button>
                </div>
              </form>
            </div>
          <% } %>
        </div>
      </div>

      <h3>Disciplinas do Curso</h3>
      <% if (fichaDisciplinas.length) { %>
        <table>
          <tr><th>Disciplina</th><th>Sigla</th></tr>
          <% fichaDisciplinas.forEach(d => { %>
            <tr><td><%= d.Disciplina %></td><td><%= d.Sigla %></td></tr>
          <% }) %>
        </table>
      <% } else { %>
        <p>Não existem disciplinas associadas a este curso.</p>
      <% } %>
    <% } else { %>
      <h2>Matrículas</h2>

      <!-- Filters Row with Inline CSS -->
      <div style="display: flex; flex-direction: column; gap: 1.25rem; align-items: stretch; background: #F3F4F6; border: 2px solid #E5E7EB; border-radius: 8px; padding: 1.25rem; margin-bottom: 2rem; width: 100%;">
        <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%;">
          <label style="display: block; margin: 0; font-weight: 600; font-size: 0.9rem; color: #111827; text-transform: uppercase; letter-spacing: 0.05em;">Pesquisar por Nome</label>
          <input type="text" placeholder="Nome do Aluno" style="width: 100%; padding: 0.875rem 1rem; background: #FFFFFF; border: none; border-radius: 6px; font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 0.95rem; color: #111827; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);" />
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%;">
          <label style="display: block; margin: 0; font-weight: 600; font-size: 0.9rem; color: #111827; text-transform: uppercase; letter-spacing: 0.05em;">Filtrar por Curso</label>
          <select style="width: 100%; padding: 0.875rem 1rem; background: #FFFFFF; border: none; border-radius: 6px; font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 0.95rem; color: #111827; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); appearance: none; background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23111827%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22%3e%3cpolyline points=%226 9 12 15 18 9%22%3e%3c/polyline%3e%3c/svg%3e'); background-repeat: no-repeat; background-position: right 0.75rem center; background-size: 1.25rem; padding-right: 2.5rem;">
            <option value="">Todos os Cursos</option>
            <% cursos.forEach(c => { %>
              <option value="<%= c.IdCurso %>"><%= c.Curso %></option>
            <% }) %>
          </select>
        </div>

        <div style="display: flex; flex-direction: column; gap: 0.5rem; width: 100%;">
          <label style="display: block; margin: 0; font-weight: 600; font-size: 0.9rem; color: #111827; text-transform: uppercase; letter-spacing: 0.05em;">Filtrar por Estado</label>
          <select style="width: 100%; padding: 0.875rem 1rem; background: #FFFFFF; border: none; border-radius: 6px; font-family: 'Outfit', -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 0.95rem; color: #111827; cursor: pointer; transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1); appearance: none; background-image: url('data:image/svg+xml;charset=UTF-8,%3csvg xmlns=%22http://www.w3.org/2000/svg%22 viewBox=%220 0 24 24%22 fill=%22none%22 stroke=%22%23111827%22 stroke-width=%222%22 stroke-linecap=%22round%22 stroke-linejoin=%22round%22%3e%3cpolyline points=%226 9 12 15 18 9%22%3e%3c/polyline%3e%3c/svg%3e'); background-repeat: no-repeat; background-position: right 0.75rem center; background-size: 1.25rem; padding-right: 2.5rem;">
            <option value="">Todos os Estados</option>
            <option value="Aprovada">Aprovada</option>
            <option value="Rejeitada">Rejeitada</option>
            <option value="Pendente">Pendente</option>
          </select>
        </div>
      </div>

      <h3>Matrículas Aceites</h3>
      <div class="table-scroll">
        <table>
          <tr><th>ID</th><th>Nome</th><th>Curso</th><th>Nascimento</th><th>Email</th><th>Telefone</th><th>Estado</th><th>Ações</th></tr>
          <% rowsMatriculasAceites.forEach(m => { %>
            <tr>
              <td><%= m.IdAluno %></td>
              <td><%= m.Nome %></td>
              <td><%= m.Curso %></td>
              <td><%= formatDatePt(m.DataNascimento) %></td>
              <td><%= m.Email || '-' %></td>
              <td><%= m.Telefone || '-' %></td>
              <td><span class="<%= estadoBadgeClass(m.EstadoValidacao) %>"><%= m.EstadoValidacao || 'Aprovada' %></span></td>
              <td class="actions">
                <a class="table-action-btn view" href="/gestor?table=matriculas&action=ficha&id_aluno=<%= m.IdAluno %>">Ver ficha</a>
                <form class="inline" method="post" action="/gestor" onsubmit="return confirm('Remover matrícula?')">
                  <input type="hidden" name="table"   value="matriculas">
                  <input type="hidden" name="action"  value="delete">
                  <input type="hidden" name="IdAluno" value="<%= m.IdAluno %>">
                  <button class="table-action-btn danger-button" type="submit">Eliminar</button>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!rowsMatriculasAceites.length) { %>
            <tr><td colspan="8">Sem matrículas aceites.</td></tr>
          <% } %>
        </table>
      </div>

      <h3>Matrículas Pendentes / Rejeitadas</h3>
      <div class="table-scroll">
        <table>
          <tr><th>ID</th><th>Nome</th><th>Curso</th><th>Nascimento</th><th>Email</th><th>Telefone</th><th>Estado</th><th>Ações</th></tr>
          <% rowsMatriculasPendentesRejeitadas.forEach(m => { %>
            <tr>
              <td><%= m.IdAluno %></td>
              <td><%= m.Nome %></td>
              <td><%= m.Curso %></td>
              <td><%= formatDatePt(m.DataNascimento) %></td>
              <td><%= m.Email || '-' %></td>
              <td><%= m.Telefone || '-' %></td>
              <td><span class="<%= estadoBadgeClass(m.EstadoValidacao) %>"><%= m.EstadoValidacao || 'Pendente' %></span></td>
              <td class="actions">
                <div style="display:flex; flex-direction:column; gap:0.75rem;">
                  <form method="post" action="/gestor" style="display:flex; flex-direction:column; gap:0.4rem;">
                    <input type="hidden" name="table" value="matriculas">
                    <input type="hidden" name="action" value="set_validation">
                    <input type="hidden" name="IdAluno" value="<%= m.IdAluno %>">
                    <label style="font-size:0.85rem; font-weight:600;">Observação</label>
                    <textarea name="ObservacoesValidacao" maxlength="255" rows="2" placeholder="Observação opcional"></textarea>
                    <div style="display:flex; gap:0.5rem;">
                      <button class="table-action-btn" type="submit" name="EstadoValidacao" value="Aprovada">Aprovar</button>
                      <button class="table-action-btn danger-button" type="submit" name="EstadoValidacao" value="Rejeitada" onclick="return confirm('Rejeitar esta ficha?')">Rejeitar</button>
                    </div>
                  </form>
                  <a class="table-action-btn view" href="/gestor?table=matriculas&action=ficha&id_aluno=<%= m.IdAluno %>">Ver ficha</a>
                  <form class="inline" method="post" action="/gestor" onsubmit="return confirm('Remover matrícula?')">
                    <input type="hidden" name="table"   value="matriculas">
                    <input type="hidden" name="action"  value="delete">
                    <input type="hidden" name="IdAluno" value="<%= m.IdAluno %>">
                    <button class="table-action-btn danger-button" type="submit">Eliminar</button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
          <% if (!rowsMatriculasPendentesRejeitadas.length) { %>
            <tr><td colspan="8">Sem matrículas pendentes/rejeitadas.</td></tr>
          <% } %>
        </table>
      </div>

      <div class="form-box">
        <h3>Nova Matrícula</h3>
        <form method="post" action="/gestor" enctype="multipart/form-data">
          <input type="hidden" name="table"  value="matriculas">
          <input type="hidden" name="action" value="create">

          <label>ID Aluno</label><br>
          <input type="number" name="IdAluno" min="1" required><br>

          <label>Nome</label><br>
          <input type="text" name="Nome" maxlength="25" required><br>

          <label>Curso</label><br>
          <select name="IdCurso" required>
            <option value="">Selecione</option>
            <% cursos.forEach(c => { %>
              <option value="<%= c.IdCurso %>"><%= c.Curso %></option>
            <% }) %>
          </select><br>

          <label>Data de nascimento</label><br>
          <input type="date" name="DataNascimento" required max="<%= dataMaximaNascimento %>"><br>

          <label>Morada</label><br>
          <input type="text" name="Morada" maxlength="255" required><br>

          <label>Email</label><br>
          <input type="email" name="Email" maxlength="120" required><br>

          <label>Contacto telefónico</label><br>
          <input type="text" name="Telefone" maxlength="9" inputmode="numeric" pattern="[0-9]{1,9}" required><br>

          <label>Foto</label><br>
          <input type="file" name="Foto" accept=".jpg,.png" required><br><br>

          <button type="submit">Criar</button>
        </form>
      </div>
    <% } %>
  <% } %>

  <!-- ═══ PLANO DE ESTUDOS ══════════════════════════════════════ -->
  <% if (table === 'plano_estudos') { %>
    <h2>Plano de Estudos</h2>
    <div class="table-scroll">
      <table>
        <tr><th>Disciplina</th><th>Curso</th><th>Ano</th><th>Semestre</th><th>Ações</th></tr>
        <% rowsPlano.forEach(row => { %>
          <tr>
            <td><%= row.Disciplina %></td>
            <td><%= row.Curso %></td>
            <td><%= row.Ano %></td>
            <td><%= row.Semestre %></td>
            <td class="actions">
              <a class="table-action-btn"
                 href="/gestor?table=plano_estudos&action=edit&id_disciplina=<%= row.IdDisciplina %>&id_curso=<%= row.IdCurso %>">
                Editar
              </a>
              <form class="inline" method="post" action="/gestor"
                    onsubmit="return confirm('Remover ligação?')">
                <input type="hidden" name="table"       value="plano_estudos">
                <input type="hidden" name="action"      value="delete">
                <input type="hidden" name="IdDisciplina" value="<%= row.IdDisciplina %>">
                <input type="hidden" name="IdCurso"     value="<%= row.IdCurso %>">
                <button class="table-action-btn danger-button" type="submit">Eliminar</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (!rowsPlano.length) { %>
          <tr><td colspan="5">Nenhuma ligação no plano de estudos.</td></tr>
        <% } %>
      </table>
    </div>

    <div class="form-box">
      <h3><%= editData ? 'Editar Ligação' : 'Nova Ligação' %></h3>
      <form method="post" action="/gestor">
        <input type="hidden" name="table"  value="plano_estudos">
        <input type="hidden" name="action" value="<%= editData ? 'update' : 'create' %>">
        <% if (editData) { %>
          <input type="hidden" name="old_IdDisciplina" value="<%= editData.IdDisciplina %>">
          <input type="hidden" name="old_IdCurso"      value="<%= editData.IdCurso %>">
        <% } %>

        <label>Disciplina</label><br>
        <select name="IdDisciplina" required>
          <option value="">Selecione</option>
          <% disciplinas.forEach(d => { %>
            <option value="<%= d.IdDisciplina %>"
              <%= editData && editData.IdDisciplina == d.IdDisciplina ? 'selected' : '' %>>
              <%= d.Disciplina %>
            </option>
          <% }) %>
        </select><br>

        <label>Curso</label><br>
        <select name="IdCurso" required>
          <option value="">Selecione</option>
          <% cursos.forEach(c => { %>
            <option value="<%= c.IdCurso %>"
              <%= editData && editData.IdCurso == c.IdCurso ? 'selected' : '' %>>
              <%= c.Curso %>
            </option>
          <% }) %>
        </select><br>

        <label>Ano</label><br>
        <input type="number" name="Ano" min="1" max="10" required
               value="<%= editData ? (editData.Ano || 1) : 1 %>"><br>

        <label>Semestre</label><br>
        <select name="Semestre" required>
          <option value="1" <%= !editData || editData.Semestre == 1 ? 'selected' : '' %>>1</option>
          <option value="2" <%= editData && editData.Semestre == 2 ? 'selected' : '' %>>2</option>
        </select><br>

        <button type="submit"><%= editData ? 'Atualizar' : 'Criar' %></button>
        <% if (editData) { %>
          <a class="cancel-link" href="/gestor?table=plano_estudos">Cancelar</a>
        <% } %>
      </form>
    </div>
  <% } %>

</div>
</body>
</html>
