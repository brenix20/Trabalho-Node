<!DOCTYPE html>
<html lang="pt">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Funcionário — IPCAVNF</title>  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@400;500;600;700;800&display=swap" rel="stylesheet">  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
  <link rel="stylesheet" href="/styles.css">
</head>
<body>
<%- include('../partials/navbar') %>

<div class="main-container">
  <% function estadoBadgeClass(estado) {
      if (estado === 'Aprovada') return 'badge-estado badge-estado-aprovada';
      if (estado === 'Rejeitada') return 'badge-estado badge-estado-rejeitada';
      return 'badge-estado badge-estado-pendente';
    } %>

  <% if (mensagem) { %>
    <div class="message <%= tipo %>"><%= mensagem %></div>
  <% } %>

  <!-- ═══ PEDIDOS ═══════════════════════════════════════════════ -->
  <% if (section === 'pedidos') { %>
    <h2>Pedidos de Matrícula</h2>

    <!-- Filtro de estado -->
     <form method="get" action="/funcionario" class="filter-grid">
      <input type="hidden" name="section" value="pedidos">
         <div class="filter-field">
           <label class="filter-label">Estado</label>
           <select name="estado_pedido" class="filter-select">
          <% ['Pendente','Aprovado','Rejeitado'].forEach(e => { %>
            <option value="<%= e %>"><%= e %></option>
          <% }) %>
        </select>
      </div>
         <div class="filter-field"><button type="submit" class="filter-button">Filtrar</button></div>
    </form>

    <div class="table-scroll">
      <table>
        <tr><th>ID</th><th>Candidato</th><th>Aluno</th><th>Curso</th><th>Data</th><th>Estado</th><th>Ações</th></tr>
        <% pedidos.forEach(p => { %>
          <tr>
            <td><%= p.IdPedido %></td>
            <td><%= p.NomeCandidato %></td>
            <td><%= p.NomeAluno || '-' %></td>
            <td><%= p.Curso || '-' %></td>
            <td><%= formatDatePt(String(p.DataPedido || '').slice(0,10)) %></td>
            <td><%= p.Estado %></td>
            <td class="actions">
              <% if (p.Estado === 'Pendente') { %>
                <form class="inline" method="post" action="/funcionario" style="display:flex; flex-direction:column; gap:0.4rem;">
                  <input type="hidden" name="post_action" value="decidir_pedido">
                  <input type="hidden" name="IdPedido"    value="<%= p.IdPedido %>">
                  <div style="display:flex; gap:0.5rem;">
                    <button class="table-action-btn" type="submit" name="decisao" value="validar">Aprovar</button>
                    <button class="table-action-btn danger-button" type="submit" name="decisao" value="rejeitar" onclick="return confirm('Rejeitar este pedido?')">Rejeitar</button>
                  </div>
                </form>
              <% } else { %>
                <span>—</span>
              <% } %>
            </td>
          </tr>
        <% }) %>
        <% if (!pedidos.length) { %>
          <tr><td colspan="7">Sem pedidos para os filtros selecionados.</td></tr>
        <% } %>
      </table>
    </div>
  <% } %>

  <!-- ═══ MATRÍCULAS ═══════════════════════════════════════════ -->
  <% if (section === 'matriculas') { %>
    <% if (action === 'view' && alunoDetalhes) { %>
      <!-- VER FICHA COMPLETA -->
      <div style="margin-bottom: 2rem;">
        <a href="/funcionario?section=matriculas" class="cancel-link" style="margin-bottom: 1rem; display: inline-block;">
          <i class="fas fa-arrow-left"></i> Voltar
        </a>
      </div>

      <div class="ficha-box">
        <div class="ficha-foto">
          <img src="/funcionario/foto?id=<%= alunoDetalhes.IdAluno %>"
               alt="<%= alunoDetalhes.Nome %>" 
               onerror="this.style.display='none'" 
               style="width: 140px; height: 160px; object-fit: cover; border-radius: 8px; border: 2px solid var(--border);">
        </div>
        
        <div class="ficha-dados">
          <p><strong>ID Aluno:</strong> <%= alunoDetalhes.IdAluno %></p>
          <p><strong>Nome:</strong> <%= alunoDetalhes.Nome %></p>
          <p><strong>Curso:</strong> <%= alunoDetalhes.Curso %></p>
          <p><strong>Data de Nascimento:</strong> <%= alunoDetalhes.DataNascimento %></p>
          <p><strong>Email:</strong> <%= alunoDetalhes.Email || '-' %></p>
          <p><strong>Telefone:</strong> <%= alunoDetalhes.Telefone || '-' %></p>
          <p><strong>Morada:</strong> <%= alunoDetalhes.Morada || '-' %></p>
          <p><strong>Estado da Validação:</strong> 
            <span class="<%= estadoBadgeClass(alunoDetalhes.EstadoValidacao) %>">
              <%= alunoDetalhes.EstadoValidacao || 'Pendente' %>
            </span>
          </p>
          <% if (alunoDetalhes.DataValidacao) { %>
            <p><strong>Validado Por:</strong> <%= alunoDetalhes.ValidadoPor || '-' %></p>
            <p><strong>Data de Validação:</strong> <%= formatDatePt(alunoDetalhes.DataValidacao) %></p>
          <% } %>
          <% if (alunoDetalhes.ObservacoesValidacao) { %>
            <p><strong>Observações:</strong> <%= alunoDetalhes.ObservacoesValidacao %></p>
          <% } %>
        </div>
      </div>

      <% if (alunoDetalhes.EstadoValidacao === 'Pendente') { %>
        <div style="margin-top: 2rem; display: flex; gap: 1rem;">
          <form method="post" action="/funcionario" style="flex: 1;">
            <input type="hidden" name="post_action" value="decidir_matricula">
            <input type="hidden" name="IdAluno"     value="<%= alunoDetalhes.IdAluno %>">
            <input type="hidden" name="decisao"     value="validar">
            <button type="submit" style="width: 100%; background: var(--secondary); color: var(--background); padding: 1rem; border-radius: 6px; font-weight: 600; border: none; cursor: pointer;">
              <i class="fas fa-check"></i> Aprovar Ficha
            </button>
          </form>
          <form method="post" action="/funcionario" style="flex: 1;" onsubmit="return confirm('Tem certeza que quer rejeitar esta ficha?');">
            <input type="hidden" name="post_action" value="decidir_matricula">
            <input type="hidden" name="IdAluno"     value="<%= alunoDetalhes.IdAluno %>">
            <input type="hidden" name="decisao"     value="rejeitar">
            <button type="submit" style="width: 100%; background: var(--danger); color: var(--background); padding: 1rem; border-radius: 6px; font-weight: 600; border: none; cursor: pointer;">
              <i class="fas fa-times"></i> Rejeitar Ficha
            </button>
          </form>
        </div>
      <% } %>
    <% } else { %>
      <!-- LISTA DE MATRÍCULAS -->
      <h2><i class="fas fa-file-alt"></i> Matrículas Aceites</h2>
    <p style="color: var(--foreground); opacity: 0.8; margin-bottom: 1.5rem;">
      Aqui aparecem apenas as matrículas aprovadas dos alunos.
    </p>

    <form method="get" action="/funcionario" class="filter-grid">
      <input type="hidden" name="section" value="matriculas">
      <div class="filter-field">
        <label class="filter-label">Pesquisar</label>
        <input type="text" name="q" placeholder="ID ou nome" class="filter-input">
      </div>
      <div class="filter-field">
        <label class="filter-label">Curso</label>
        <select name="filtro_curso" class="filter-select">
          <option value="0">Todos</option>
          <% cursos.forEach(c => { %>
            <option value="<%= c.IdCurso %>"><%= c.Curso %></option>
          <% }) %>
        </select>
      </div>
      <div class="filter-field"><button type="submit" class="filter-button">Filtrar</button></div>
    </form>

    <div class="table-scroll">
      <table>
        <tr><th>ID</th><th>Nome</th><th>Curso</th><th>Email</th><th>Telefone</th><th>Estado</th><th>Ações</th></tr>
        <% matriculas.forEach(m => { %>
          <tr>
            <td><%= m.IdAluno %></td>
            <td><%= m.Nome %></td>
            <td><%= m.Curso %></td>
            <td><%= m.Email || '-' %></td>
            <td><%= m.Telefone || '-' %></td>
            <td>
              <span class="<%= estadoBadgeClass(m.EstadoValidacao) %>">
                <%= m.EstadoValidacao || 'Pendente' %>
              </span>
            </td>
            <td class="actions">
              <a class="table-action-btn" href="/funcionario?section=matriculas&action=view&id=<%= m.IdAluno %>">
                <i class="fas fa-eye"></i> Ver Ficha
              </a>
            </td>
          </tr>
        <% }) %>
        <% if (!matriculas.length) { %>
          <tr><td colspan="7" style="text-align: center; padding: 2rem;">Sem matrículas aceites para os filtros selecionados.</td></tr>
        <% } %>
      </table>
    </div>
    <% } %>
  <% } %>

  <!-- ═══ PEDIDOS DE FICHA DE ALUNOS ═════════════════════════════ -->
  <% if (section === 'pedidos_fichas') { %>
    <% if (action === 'view' && pedidoFichaDetalhes) { %>
      <!-- VER PEDIDO DE FICHA COMPLETO -->
      <div style="margin-bottom: 2rem;">
        <a href="/funcionario?section=pedidos_fichas" class="cancel-link" style="margin-bottom: 1rem; display: inline-block;">
          <i class="fas fa-arrow-left"></i> Voltar
        </a>
      </div>

      <div class="ficha-box">
        <div class="ficha-foto">
          <img src="/funcionario/foto?id=<%= pedidoFichaDetalhes.IdAluno %>"
               alt="<%= pedidoFichaDetalhes.Nome %>" 
               onerror="this.style.display='none'" 
               style="width: 140px; height: 160px; object-fit: cover; border-radius: 8px; border: 2px solid var(--border);">
        </div>
        
        <div class="ficha-dados">
          <p><strong>ID Aluno:</strong> <%= pedidoFichaDetalhes.IdAluno %></p>
          <p><strong>Nome:</strong> <%= pedidoFichaDetalhes.Nome %></p>
          <p><strong>Curso:</strong> <%= pedidoFichaDetalhes.Curso %></p>
          <p><strong>Data de Nascimento:</strong> <%= pedidoFichaDetalhes.DataNascimento %></p>
          <p><strong>Email:</strong> <%= pedidoFichaDetalhes.Email || '-' %></p>
          <p><strong>Telefone:</strong> <%= pedidoFichaDetalhes.Telefone || '-' %></p>
          <p><strong>Morada:</strong> <%= pedidoFichaDetalhes.Morada || '-' %></p>
          <p><strong>Estado da Solicitação:</strong> 
            <span class="badge-estado badge-estado-pendente">
              Pendente
            </span>
          </p>
        </div>
      </div>

      <div style="margin-top: 2rem; display: flex; gap: 1rem;">
        <form method="post" action="/funcionario" style="flex: 1; display:flex; flex-direction:column; gap:0.4rem;">
          <input type="hidden" name="post_action" value="decidir_ficha">
          <input type="hidden" name="origem" value="pedidos_fichas">
          <input type="hidden" name="IdAluno"     value="<%= pedidoFichaDetalhes.IdAluno %>">
          <div style="display:flex; gap:1rem;">
            <button type="submit" name="decisao" value="validar" style="flex: 1; background: var(--secondary); color: var(--background); padding: 1rem; border-radius: 6px; font-weight: 600; border: none; cursor: pointer;">
              <i class="fas fa-check"></i> Aceitar Ficha
            </button>
            <button type="submit" name="decisao" value="rejeitar" onclick="return confirm('Tem certeza que quer rejeitar esta solicitação?');" style="flex: 1; background: var(--danger); color: var(--background); padding: 1rem; border-radius: 6px; font-weight: 600; border: none; cursor: pointer;">
              <i class="fas fa-times"></i> Rejeitar Ficha
            </button>
          </div>
        </form>
      </div>
    <% } else { %>
      <!-- LISTA DE PEDIDOS DE FICHA DE ALUNOS -->
      <h2><i class="fas fa-file-import"></i> Pedidos de Ficha de Alunos</h2>
      <p style="color: var(--foreground); opacity: 0.8; margin-bottom: 1.5rem;">
        Verifique, aceite ou rejeite os pedidos de ficha de alunos.
      </p>

      <form method="get" action="/funcionario" class="filter-grid">
        <input type="hidden" name="section" value="pedidos_fichas">
        <div class="filter-field">
          <label class="filter-label">Pesquisar</label>
          <input type="text" name="q" placeholder="ID ou nome" class="filter-input">
        </div>
        <div class="filter-field">
          <label class="filter-label">Curso</label>
          <select name="filtro_curso" class="filter-select">
            <option value="0">Todos</option>
            <% cursos.forEach(c => { %>
              <option value="<%= c.IdCurso %>"><%= c.Curso %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-field"><button type="submit" class="filter-button">Filtrar</button></div>
      </form>

      <div class="table-scroll">
        <table>
          <tr><th>ID</th><th>Nome</th><th>Curso</th><th>Email</th><th>Telefone</th><th>Estado</th><th>Ações</th></tr>
          <% pedidosFichas.forEach(p => { %>
            <tr>
              <td><%= p.IdAluno %></td>
              <td><%= p.Nome %></td>
              <td><%= p.Curso %></td>
              <td><%= p.Email || '-' %></td>
              <td><%= p.Telefone || '-' %></td>
              <td>
                <span style="padding: 0.3rem 0.6rem; border-radius: 4px; font-size: 0.85rem; font-weight: 600; background: var(--accent); color: var(--foreground);">
                  Pendente
                </span>
              </td>
              <td class="actions">
                <a class="table-action-btn" href="/funcionario?section=pedidos_fichas&action=view&id=<%= p.IdAluno %>">
                  <i class="fas fa-eye"></i> Ver Pedido
                </a>
                <form class="inline" method="post" action="/funcionario" style="display:flex; flex-direction:column; gap:0.4rem;">
                  <input type="hidden" name="post_action" value="decidir_ficha">
                  <input type="hidden" name="origem" value="pedidos_fichas">
                  <input type="hidden" name="IdAluno"     value="<%= p.IdAluno %>">
                  <div style="display:flex; gap:0.5rem;">
                    <button class="table-action-btn" type="submit" name="decisao" value="validar"><i class="fas fa-check"></i> Aceitar</button>
                    <button class="table-action-btn danger-button" type="submit" name="decisao" value="rejeitar" onclick="return confirm('Rejeitar este pedido de ficha?')"><i class="fas fa-times"></i> Rejeitar</button>
                  </div>
                </form>
              </td>
            </tr>
          <% }) %>
          <% if (!pedidosFichas.length) { %>
            <tr><td colspan="7" style="text-align: center; padding: 2rem;">Sem pedidos de ficha pendentes.</td></tr>
          <% } %>
        </table>
      </div>
    <% } %>
  <% } %>

  <!-- ═══ FICHAS DE ALUNO ═════════════════════════════════════ -->
  <% if (section === 'fichasaluno') { %>
    <% if (action === 'view' && fichaAlunoDetalhes) { %>
      <!-- VER FICHA COMPLETA -->
      <div style="margin-bottom: 2rem;">
        <a href="/funcionario?section=fichasaluno" class="cancel-link" style="margin-bottom: 1rem; display: inline-block;">
          <i class="fas fa-arrow-left"></i> Voltar
        </a>
      </div>

      <div class="ficha-box">
        <div class="ficha-foto">
          <img src="/funcionario/foto?id=<%= fichaAlunoDetalhes.IdAluno %>"
               alt="<%= fichaAlunoDetalhes.Nome %>" 
               onerror="this.style.display='none'" 
               style="width: 140px; height: 160px; object-fit: cover; border-radius: 8px; border: 2px solid var(--border);">
        </div>
        
        <div class="ficha-dados">
          <p><strong>ID Aluno:</strong> <%= fichaAlunoDetalhes.IdAluno %></p>
          <p><strong>Nome:</strong> <%= fichaAlunoDetalhes.Nome %></p>
          <p><strong>Curso:</strong> <%= fichaAlunoDetalhes.Curso %></p>
          <p><strong>Data de Nascimento:</strong> <%= fichaAlunoDetalhes.DataNascimento %></p>
          <p><strong>Email:</strong> <%= fichaAlunoDetalhes.Email || '-' %></p>
          <p><strong>Telefone:</strong> <%= fichaAlunoDetalhes.Telefone || '-' %></p>
          <p><strong>Morada:</strong> <%= fichaAlunoDetalhes.Morada || '-' %></p>
          <p><strong>Estado da Validação:</strong> 
            <span class="<%= estadoBadgeClass(fichaAlunoDetalhes.EstadoValidacao) %>">
              <%= fichaAlunoDetalhes.EstadoValidacao || 'Pendente' %>
            </span>
          </p>
          <% if (fichaAlunoDetalhes.DataValidacao) { %>
            <p><strong>Validado Por:</strong> <%= fichaAlunoDetalhes.ValidadoPor || '-' %></p>
            <p><strong>Data de Validação:</strong> <%= formatDatePt(fichaAlunoDetalhes.DataValidacao) %></p>
          <% } %>
          <% if (fichaAlunoDetalhes.ObservacoesValidacao) { %>
            <p><strong>Observações:</strong> <%= fichaAlunoDetalhes.ObservacoesValidacao %></p>
          <% } %>
        </div>
      </div>
    <% } else { %>
      <!-- LISTA DE FICHAS DE ALUNO -->
      <h2><i class="fas fa-file-contract"></i> Fichas de Aluno</h2>
      <p style="color: var(--foreground); opacity: 0.8; margin-bottom: 1.5rem;">
        Verifique, aceite ou rejeite as fichas de aluno.
      </p>

       <form method="get" action="/funcionario" class="filter-grid">
        <input type="hidden" name="section" value="fichasaluno">
         <div class="filter-field">
           <label class="filter-label">Pesquisar</label>
           <input type="text" name="q" placeholder="ID ou nome" class="filter-input">
        </div>
         <div class="filter-field">
           <label class="filter-label">Curso</label>
           <select name="filtro_curso" class="filter-select">
            <option value="0">Todos</option>
            <% cursos.forEach(c => { %>
              <option value="<%= c.IdCurso %>"><%= c.Curso %></option>
            <% }) %>
          </select>
        </div>
         <div class="filter-field"><button type="submit" class="filter-button">Filtrar</button></div>
      </form>

      <div class="table-scroll">
        <table>
          <tr><th>ID</th><th>Nome</th><th>Curso</th><th>Email</th><th>Telefone</th><th>Estado</th><th>Ações</th></tr>
          <% fichasAlunos.forEach(f => { %>
            <tr>
              <td><%= f.IdAluno %></td>
              <td><%= f.Nome %></td>
              <td><%= f.Curso %></td>
              <td><%= f.Email || '-' %></td>
              <td><%= f.Telefone || '-' %></td>
              <td>
                <span class="<%= estadoBadgeClass(f.EstadoValidacao) %>">
                  <%= f.EstadoValidacao || 'Pendente' %>
                </span>
              </td>
              <td class="actions">
                <a class="table-action-btn" href="/funcionario?section=fichasaluno&action=view&id=<%= f.IdAluno %>">
                  <i class="fas fa-eye"></i> Ver Ficha
                </a>
                <% if (f.EstadoValidacao === 'Pendente') { %>
                  <form class="inline" method="post" action="/funcionario" style="display:flex; flex-direction:column; gap:0.4rem;">
                    <input type="hidden" name="post_action" value="decidir_ficha">
                    <input type="hidden" name="IdAluno"     value="<%= f.IdAluno %>">
                    <div style="display:flex; gap:0.5rem;">
                      <button class="table-action-btn" type="submit" name="decisao" value="validar"><i class="fas fa-check"></i> Aceitar</button>
                      <button class="table-action-btn danger-button" type="submit" name="decisao" value="rejeitar" onclick="return confirm('Rejeitar esta ficha?')"><i class="fas fa-times"></i> Rejeitar</button>
                    </div>
                  </form>
                <% } %>
              </td>
            </tr>
          <% }) %>
          <% if (!fichasAlunos.length) { %>
            <tr><td colspan="7" style="text-align: center; padding: 2rem;">Sem fichas para os filtros selecionados.</td></tr>
          <% } %>
        </table>
      </div>
    <% } %>
  <% } %>

  <!-- ═══ NOTAS ═════════════════════════════════════════════════ -->
  <% if (section === 'notas') { %>
    <h2>Notas de Avaliação</h2>

    <!-- Formulário criar/editar nota -->
    <div class="form-box">
      <h3><%= notaEdit ? 'Editar nota' : 'Registar nota' %></h3>
      <form method="post" action="/funcionario">
        <input type="hidden" name="post_action" value="guardar_nota">
        <% if (notaEdit) { %>
          <input type="hidden" name="IdNota" value="<%= notaEdit.IdNota %>">
        <% } %>

        <label>Aluno</label><br>
        <select id="IdAluno" name="IdAluno" required>
          <option value="">Selecionar aluno</option>
          <% alunosSelect.forEach(a => { %>
            <option value="<%= a.IdAluno %>" data-curso-id="<%= a.IdCurso %>"
              <%= notaEdit && notaEdit.IdAluno == a.IdAluno ? 'selected' : '' %>>
              <%= a.IdAluno %> — <%= a.Nome %>
            </option>
          <% }) %>
        </select><br>

        <label>Disciplina</label><br>
        <select id="IdDisciplina" name="IdDisciplina" required>
          <option value="">Selecionar aluno primeiro</option>
          <% disciplinas.forEach(d => { %>
            <option value="<%= d.IdDisciplina %>"
              data-cursos="<%= d.cursos || '' %>"
              <%= notaEdit && notaEdit.IdDisciplina == d.IdDisciplina ? 'selected' : '' %>>
              <%= d.Disciplina %>
            </option>
          <% }) %>
        </select><br>

        <label>Época</label><br>
        <select name="Epoca" required>
          <% ['Normal','Recurso','Especial'].forEach(e => { %>
            <option value="<%= e %>"
              <%= notaEdit && notaEdit.Epoca === e ? 'selected' : (e === 'Normal' && !notaEdit ? 'selected' : '') %>>
              <%= e %>
            </option>
          <% }) %>
        </select><br>

        <label>Ano letivo (ex: 2024/2025)</label><br>
        <input type="text" name="AnoLetivo" pattern="\d{4}/\d{4}" required
               value="<%= notaEdit ? notaEdit.AnoLetivo : anoLetivoAtual %>"><br>

        <label>Nota (0–20)</label><br>
        <input type="number" name="Nota" min="0" max="20" step="0.1" required
               value="<%= notaEdit ? notaEdit.Nota : '' %>"><br>

        <label>Observações</label><br>
        <input type="text" name="Observacoes" maxlength="255"
               value="<%= notaEdit ? (notaEdit.Observacoes || '') : '' %>"><br>

        <button type="submit"><%= notaEdit ? 'Atualizar nota' : 'Registar nota' %></button>
        <% if (notaEdit) { %>
          <a class="cancel-link" href="/funcionario?section=notas">Cancelar</a>
        <% } %>
      </form>
    </div>

    <!-- Filtros de notas -->
     <form method="get" action="/funcionario" class="filter-grid">
      <input type="hidden" name="section" value="notas">
         <div class="filter-field">
           <label class="filter-label">Disciplina</label>
           <select name="f_disciplina" class="filter-select">
          <option value="0">Todas</option>
          <% disciplinas.forEach(d => { %>
            <option value="<%= d.IdDisciplina %>"><%= d.Disciplina %></option>
          <% }) %>
        </select>
      </div>
         <div class="filter-field">
           <label class="filter-label">Pesquisar</label>
           <input type="text" name="q_nota" placeholder="Aluno, ID ou disciplina" class="filter-input">
      </div>
         <div class="filter-field"><button type="submit" class="filter-button">Aplicar</button></div>
    </form>

    <div class="notas-scroll">
      <table>
        <tr>
          <th>Aluno</th><th>Disciplina</th><th>Curso</th>
          <th>Época</th><th>Ano letivo</th><th>Nota</th><th>Resultado</th><th>Ações</th>
        </tr>
        <% rowsNotas.forEach(n => { %>
          <% const resultado = parseFloat(n.Nota) >= 9.5 ? 'Aprovado' : 'Reprovado'; %>
          <tr>
            <td><%= n.IdAluno %> — <%= n.NomeAluno %></td>
            <td><%= n.Disciplina %></td>
            <td><%= n.Curso || '' %></td>
            <td><%= n.Epoca %></td>
            <td><%= n.AnoLetivo %></td>
            <td><%= parseFloat(n.Nota).toFixed(1) %></td>
            <td><%= resultado %></td>
            <td class="actions notas-actions">
              <a class="table-action-btn edit-action-btn"
                 href="/funcionario?section=notas&action=edit&id_nota=<%= n.IdNota %>">Editar</a>
              <form class="inline" method="post" action="/funcionario"
                    onsubmit="return confirm('Eliminar esta nota?')">
                <input type="hidden" name="post_action" value="eliminar_nota">
                <input type="hidden" name="IdNota"      value="<%= n.IdNota %>">
                <button class="table-action-btn danger-button" type="submit">Excluir</button>
              </form>
            </td>
          </tr>
        <% }) %>
        <% if (!rowsNotas.length) { %>
          <tr><td colspan="8">Não existem notas para os filtros selecionados.</td></tr>
        <% } %>
      </table>
    </div>
  <% } %>

  <!-- ═══ PAUTAS ════════════════════════════════════════════════ -->
  <% if (section === 'pautas') { %>
    <h2>Gerar Pauta de Avaliação</h2>

    <div class="form-box">
      <h3>Filtros da pauta</h3>
      <form method="get" action="/funcionario" class="filter-grid">
        <input type="hidden" name="section" value="pautas">
        <div class="filter-field">
          <label class="filter-label">Disciplina</label>
          <select name="disciplina_id" class="filter-select" required>
            <option value="0">Selecionar disciplina</option>
            <% disciplinas.forEach(d => { %>
              <option value="<%= d.IdDisciplina %>"
                <%= pautaDisciplinaId == d.IdDisciplina ? 'selected' : '' %>>
                <%= d.Disciplina %>
              </option>
            <% }) %>
          </select>
        </div>
        <div class="filter-field">
          <label class="filter-label">Época</label>
          <select name="epoca" class="filter-select">
            <% ['Normal','Recurso','Especial'].forEach(e => { %>
              <option value="<%= e %>" <%= pautaEpoca === e ? 'selected' : '' %>><%= e %></option>
            <% }) %>
          </select>
        </div>
        <div class="filter-field">
          <label class="filter-label">Ano letivo</label>
          <input type="text" name="ano_letivo" class="filter-input" pattern="\d{4}/\d{4}"
                 value="<%= pautaAnoLetivo %>" required>
        </div>
        <div class="filter-field"><button type="submit" class="filter-button">Gerar pauta</button></div>
      </form>
    </div>

    <% if (pautaDisciplinaId > 0) { %>
      <p class="stats-row">Registos: <%= rowsPauta.length %></p>
      <table>
        <tr><th>ID Aluno</th><th>Aluno</th><th>Curso</th><th>Nota</th><th>Resultado</th></tr>
        <% rowsPauta.forEach(r => { %>
          <tr>
            <td><%= r.IdAluno %></td>
            <td><%= r.NomeAluno %></td>
            <td><%= r.Curso || '' %></td>
            <td><%= parseFloat(r.Nota).toFixed(1) %></td>
            <td><%= r.Resultado %></td>
          </tr>
        <% }) %>
        <% if (!rowsPauta.length) { %>
          <tr><td colspan="5">Sem notas para os filtros selecionados.</td></tr>
        <% } %>
      </table>
    <% } else { %>
      <div class="form-box"><p>Seleciona uma disciplina para gerar a pauta.</p></div>
    <% } %>
  <% } %>
</div>

<script>
  (function () {
    var alunoSelect     = document.getElementById('IdAluno');
    var disciplinaSelect = document.getElementById('IdDisciplina');
    if (!alunoSelect || !disciplinaSelect) return;

    function filtrar() {
      var opt     = alunoSelect.options[alunoSelect.selectedIndex];
      var cursoId = opt ? String(opt.getAttribute('data-curso-id') || '') : '';
      var disp    = 0;

      for (var i = 0; i < disciplinaSelect.options.length; i++) {
        var o = disciplinaSelect.options[i];
        if (!o.value) { o.disabled = false; o.hidden = false; continue; }
        var cursos  = String(o.getAttribute('data-cursos') || '').split(',').filter(Boolean);
        var ok      = cursoId !== '' && cursos.indexOf(cursoId) !== -1;
        o.disabled  = !ok;
        o.hidden    = !ok;
        if (ok) disp++;
      }

      var sel = disciplinaSelect.options[disciplinaSelect.selectedIndex];
      if (sel && sel.value && sel.disabled) disciplinaSelect.value = '';

      if (disciplinaSelect.options.length > 0) {
        disciplinaSelect.options[0].text = cursoId === '' ? 'Selecionar aluno primeiro'
          : disp === 0 ? 'Sem disciplinas para o curso' : 'Selecionar disciplina';
      }
    }

    alunoSelect.addEventListener('change', filtrar);
    filtrar();
  }());
</script>
</body>
</html>
