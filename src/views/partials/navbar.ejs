<%
  const perfil = ((sessao && sessao.utilizador_perfil) || '').toLowerCase();
  const nome   = (sessao && sessao.utilizador_nome) || '';
  
  const iconMap = {
    'gestor': 'cog',
    'aluno': 'user-graduate',
    'funcionario': 'briefcase',
    'funcionário': 'briefcase'
  };
  const perfilIcon = iconMap[perfil] || 'user';
%>
<nav class="navbar">
  <span class="nav-brand">
    <i class="fas fa-graduation-cap"></i> IPCAVNF
  </span>
  
  <ul class="nav-links">
    <% if (perfil === 'gestor') { %>
      <li><a href="/gestor?table=disciplina"><i class="fas fa-book"></i> Disciplinas</a></li>
      <li><a href="/gestor?table=cursos"><i class="fas fa-graduation-cap"></i> Cursos</a></li>
      <li><a href="/gestor?table=matriculas"><i class="fas fa-users"></i> Matrículas</a></li>
      <li><a href="/gestor?table=plano_estudos"><i class="fas fa-list-check"></i> Plano de Estudos</a></li>
    <% } else if (perfil === 'aluno') { %>
      <li><a href="/aluno?table=matriculas&action=ficha"><i class="fas fa-id-card"></i> Minha Ficha</a></li>
      <li><a href="/aluno?table=matriculas&action=ficha_edit"><i class="fas fa-edit"></i> Atualizar Dados</a></li>
      <li><a href="/aluno?table=pedidos"><i class="fas fa-file-alt"></i> Pedido de Matrícula</a></li>
      <li><a href="/aluno?table=matriculas&action=minhas_disciplinas"><i class="fas fa-book"></i> Disciplinas</a></li>
      <li><a href="/aluno?table=matriculas&action=minha_turma"><i class="fas fa-users"></i> Turma</a></li>
    <% } else if (perfil === 'funcionario' || perfil === 'funcionário') { %>
      <li><a href="/funcionario?section=pedidos"><i class="fas fa-inbox"></i> Pedidos de Matrícula</a></li>
      <li><a href="/funcionario?section=matriculas"><i class="fas fa-check-square"></i> Matrículas</a></li>
      <li><a href="/funcionario?section=pedidos_fichas"><i class="fas fa-file-import"></i> Pedidos de Ficha</a></li>
      <li><a href="/funcionario?section=fichasaluno"><i class="fas fa-file-contract"></i> Fichas de Aluno</a></li>
      <li><a href="/funcionario?section=notas"><i class="fas fa-pencil-alt"></i> Notas</a></li>
      <li><a href="/funcionario?section=pautas"><i class="fas fa-file-excel"></i> Pautas</a></li>
    <% } %>
  </ul>
  
  <div class="nav-user">
    <div style="display: flex; align-items: center; gap: 0.5rem;">
      <i class="fas fa-<%= perfilIcon %>"></i>
      <span><%= nome %></span>
    </div>
    <a href="/logout" class="logout-btn">
      <i class="fas fa-sign-out-alt"></i> Sair
    </a>
  </div>
</nav>
