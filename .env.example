# Base de dados MongoDB (integração faseada)
MONGODB_URI=mongodb+srv://<db_user>:<db_password>@cluster0.wjqc1d6.mongodb.net/
MONGODB_DB=ipcavnf
MONGODB_MAX_POOL_SIZE=20
MONGODB_MIN_POOL_SIZE=5
MONGODB_MAX_IDLE_MS=300000
MONGODB_CONNECT_TIMEOUT_MS=10000
MONGODB_SOCKET_TIMEOUT_MS=30000
MONGODB_SERVER_SELECTION_TIMEOUT_MS=5000

# Sessão Express (usa um segredo longo e aleatório em produção)
SESSION_SECRET=muda_este_segredo_para_producao

# Porta do servidor
PORT=3000
